<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="AGA HOUSE - تسويق العقارات الراقية بأكادير">
<title>AGA HOUSE | Luxury Real Estate Agadir</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

<style>
/* ─── TOKENS ─────────────────────────────────────────────── */
:root {
  --g:   #c9a84c;
  --g2:  #e8cc72;
  --g3:  rgba(201,168,76,.12);
  --gb:  rgba(201,168,76,.18);
  --bg:  #060809;
  --bg2: #0c1018;
  --bg3: #111820;
  --t:   #fff;
  --t2:  rgba(255,255,255,.5);
  --t3:  rgba(255,255,255,.18);
  --ease: cubic-bezier(.16,1,.3,1);
}

/* ─── BASE ───────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  font-family:'Cairo',sans-serif;
  color:var(--t);
  overflow-x:hidden;
  cursor:default;
}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:rgba(201,168,76,.3);border-radius:2px}
a{text-decoration:none;color:inherit}
img{display:block;width:100%;object-fit:cover}

/* ─── GRAIN + BACKGROUND ORBS ───────────────────────────── */
.grain{
  position:fixed;inset:0;z-index:9999;pointer-events:none;
  opacity:.028;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:200px 200px;
}
.orb-wrap{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none}
.orb{position:absolute;border-radius:50%;filter:blur(90px);opacity:.055}
.orb-1{width:700px;height:700px;background:radial-gradient(circle,#b8922a,transparent 70%);top:-15%;right:-10%;animation:orb-a 22s ease-in-out infinite}
.orb-2{width:500px;height:500px;background:radial-gradient(circle,#1a2540,transparent 70%);bottom:-10%;left:-5%;animation:orb-b 28s ease-in-out infinite}
.orb-3{width:400px;height:400px;background:radial-gradient(circle,#c9a84c,transparent 70%);top:40%;left:30%;opacity:.03;animation:orb-c 35s ease-in-out infinite}
@keyframes orb-a{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-60px,80px) scale(1.15)}}
@keyframes orb-b{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(80px,-60px) scale(1.1)}}
@keyframes orb-c{0%,100%{transform:translate(0,0)}33%{transform:translate(50px,30px)}66%{transform:translate(-40px,-20px)}}

/* ─── REVEAL ON SCROLL ───────────────────────────────────── */
.reveal{opacity:0;transform:translateY(48px);transition:opacity .9s var(--ease),transform .9s var(--ease)}
.reveal.in{opacity:1;transform:none}
.reveal-d1{transition-delay:.1s}.reveal-d2{transition-delay:.2s}
.reveal-d3{transition-delay:.3s}.reveal-d4{transition-delay:.4s}

/* ─── NAV ────────────────────────────────────────────────── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  padding:1.4rem 2.5rem;
  transition:background .4s,border .4s,padding .3s;
}
nav.scrolled{
  background:rgba(6,8,9,.88);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-bottom:1px solid rgba(201,168,76,.1);
  padding:1rem 2.5rem;
}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between}
.nav-logo{
  font-family:'Cormorant Garamond',serif;
  font-size:1.5rem;font-weight:600;letter-spacing:.25em;
  background:linear-gradient(90deg,var(--g),var(--g2),var(--g));
  background-size:200% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;animation:shine 5s linear infinite;
}
@keyframes shine{to{background-position:200% center}}
.nav-links{display:flex;gap:2.5rem;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;color:var(--t2)}
.nav-links a{transition:color .3s}
.nav-links a:hover{color:var(--g)}
.nav-cta{
  font-size:.75rem;letter-spacing:.1em;
  border:1px solid var(--gb);
  border-radius:99px;padding:.55rem 1.4rem;
  color:var(--g);
  background:var(--g3);
  transition:background .3s,border .3s;
}
.nav-cta:hover{background:rgba(201,168,76,.22);border-color:rgba(201,168,76,.35)}

/* ─── HERO ───────────────────────────────────────────────── */
.hero{
  position:relative;z-index:1;
  min-height:100svh;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;
  padding:7rem 2rem 4rem;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:.5rem;
  border:1px solid var(--gb);border-radius:99px;
  padding:.35rem 1.1rem;font-size:.7rem;letter-spacing:.25em;
  text-transform:uppercase;color:var(--g);
  margin-bottom:2rem;
  animation:fade-in .8s var(--ease) .1s both;
}
@keyframes fade-in{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}

.hero-eyebrow{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(.8rem,1.5vw,1rem);
  font-style:italic;letter-spacing:.35em;
  color:var(--g);opacity:.7;text-transform:uppercase;
  margin-bottom:.75rem;
  animation:fade-in .8s var(--ease) .2s both;
}
.hero-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(4rem,12vw,10rem);
  font-weight:300;letter-spacing:.06em;
  line-height:.92;
  background:linear-gradient(170deg,var(--g2) 0%,var(--g) 40%,rgba(201,168,76,.6) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  margin-bottom:1.5rem;
  animation:fade-in .9s var(--ease) .3s both;
}
.hero-line{
  width:60px;height:1px;background:var(--g);opacity:.4;
  margin:0 auto 1.5rem;
  animation:expand .9s var(--ease) .5s both;
}
@keyframes expand{from{width:0;opacity:0}to{width:60px;opacity:.4}}
.hero-subtitle{
  font-size:clamp(.9rem,1.8vw,1.1rem);font-weight:300;
  color:var(--t2);letter-spacing:.12em;text-transform:uppercase;
  margin-bottom:.75rem;
  animation:fade-in .8s var(--ease) .55s both;
}
.hero-desc{
  font-size:.9rem;color:var(--t3);max-width:400px;line-height:1.8;
  margin:0 auto 2.5rem;
  animation:fade-in .8s var(--ease) .65s both;
}

/* ─── SECTION SKELETON ───────────────────────────────────── */
section{position:relative;z-index:1;padding:7rem 2rem}
.section-max{max-width:1100px;margin:0 auto}

/* ─── PROPERTY ───────────────────────────────────────────── */
.prop-wrap{
  background:rgba(255,255,255,.018);
  border:1px solid rgba(201,168,76,.12);
  border-radius:2rem;overflow:hidden;margin-top:4rem;
}

/* Location Fix */
.loc-block{
  background:rgba(201,168,76,.04);
  border:1px solid rgba(201,168,76,.12);
  border-radius:1.5rem;overflow:hidden;margin-bottom:2rem;
}
.loc-info{padding:1.25rem 1.5rem;display:flex;gap:.85rem;border-bottom:1px solid rgba(201,168,76,.08)}
.loc-info i{color:var(--g);font-size:1rem;margin-top:.15rem;flex-shrink:0}
.loc-info h4{font-size:.9rem;font-weight:700;color:var(--g);margin-bottom:.35rem}
.loc-info p{font-size:.8rem;color:var(--t2);line-height:1.7}
.map-frame{height:450px;width:100%;background:#05070a}
.map-frame iframe{width:100%;height:100%;border:0}

/* Floor toggle styles */
.floor-card .floor-body { display: none; }
.floor-card.open .floor-body { display: grid; }
.floor-card.open .chevron { transform: rotate(180deg); }

/* Language Helper Display */
[lang="ar"] .fr { display: none !important; }
[lang="fr"] .ar { display: none !important; }

/* Responsive adjustments */
@media(max-width:768px){
  .nav-links{display:none}
  .hero-title{font-size: 4.5rem;}
}
</style>
</head>
<body>

<div class="grain" aria-hidden="true"></div>
<div class="orb-wrap" aria-hidden="true">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
</div>

<nav id="nav">
  <div class="nav-inner">
    <span class="nav-logo">AGA HOUSE</span>
    <div class="nav-links">
      <a href="#properties" class="ar">العقارات</a>
      <a href="#properties" class="fr">Biens</a>
      <a href="#contact" class="ar">تواصل</a>
      <a href="#contact" class="fr">Contact</a>
    </div>
    <a href="https://wa.me/212639506866" target="_blank" class="nav-cta">
      <i class="fab fa-whatsapp"></i>
      <span class="ar">واتساب</span>
      <span class="fr">WhatsApp</span>
    </a>
  </div>
</nav>

<section class="hero" id="home">
  <div class="lang-wrap" style="margin-bottom: 2rem;">
    <div class="lang-inner" style="display:flex; background:rgba(255,255,255,0.05); border-radius:99px; padding:4px;">
      <button class="lang-btn" onclick="setLang('ar')" style="padding:8px 20px; border-radius:99px; border:none; cursor:pointer;">العربية</button>
      <button class="lang-btn" onclick="setLang('fr')" style="padding:8px 20px; border-radius:99px; border:none; cursor:pointer;">Français</button>
    </div>
  </div>

  <h1 class="hero-title">AGA HOUSE</h1>
  <p class="hero-subtitle ar">عقارات فاخرة في أكادير</p>
  <p class="hero-subtitle fr">Immobilier de luxe à Agadir</p>
</section>

<section id="properties">
  <div class="section-max">
    <div class="prop-wrap">
      <div class="loc-block">
        <div class="loc-info">
          <i class="fas fa-map-pin"></i>
          <div>
            <h4 class="ar">موقع المنزل — التمسية</h4>
            <h4 class="fr">Localisation — Timssia</h4>
            <p class="ar">المنزل متواجد في منطقة هادئة وقريب من المرافق الأساسية بالتمسية.</p>
            <p class="fr">Maison située dans un quartier calme proche des commodités à Timssia.</p>
          </div>
        </div>
        <div class="map-frame">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m13!1d1118.8!2d-9.416389!3d30.366833!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMzDCsDIyJzAwLjYiTiA5wrAyNCc1OS4wIlc!5e1!3m2!1sen!2sma!4v1710000000000!5m2!1sen!2sma&maptype=satellite" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function setLang(l) {
  document.documentElement.setAttribute('lang', l);
  document.documentElement.setAttribute('dir', l === 'ar' ? 'rtl' : 'ltr');
  // Update buttons style
  const btns = document.querySelectorAll('.lang-btn');
  btns.forEach(b => {
    b.style.background = 'transparent';
    b.style.color = 'white';
  });
  event.target.style.background = '#c9a84c';
  event.target.style.color = 'black';
}

function toggleFloor(head) {
  head.parentElement.classList.toggle('open');
}

// Default Lang
setLang('ar');
</script>

</body>
</html>
